# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://usuario:password@localhost/risvoice

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-una-clave-segura-de-256-bits
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=480
JWT_REFRESH_TTL_DAYS=7

# ── Whisper STT ───────────────────────────────────────────────────────────────
WHISPER_URL=http://localhost:8001

# ── Integración RIS via Mirth Connect ─────────────────────────────────────────
# Puerto default Mirth: 8443 (HTTPS) o 8080 (HTTP)
# El canal en Mirth debe llamarse exactamente "RISVOICE"
MIRTH_URL=http://IP-MIRTH:8443/api

# ── Integración FHIR Server (opcional) ───────────────────────────────────────
# Servidor FHIR R4 para persistir DiagnosticReport (ej: HAPI FHIR, Smile CDR)
FHIR_SERVER_URL=http://IP-FHIR:8080/fhir

# ── Integración PACS / Orthanc (opcional) ─────────────────────────────────────
# Para consultar disponibilidad de imágenes por AccessionNumber
ORTHANC_URL=http://IP-PACS:8042
ORTHANC_USER=orthanc
ORTHANC_PASSWORD=orthanc

# ── Token seguridad endpoint /worklist/integration ───────────────────────────
# Los sistemas RIS/HIS deben enviarlo en: X-Integration-Token: <valor>
# Si está vacío, el endpoint acepta cualquier llamada (solo para desarrollo)
INTEGRATION_TOKEN=cambia-esto-por-un-token-secreto-largo

# ── Aplicación ────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3020","https://ris.tudominio.cl"]
PDF_OUTPUT_DIR=./pdf_storage
APP_ENV=development
